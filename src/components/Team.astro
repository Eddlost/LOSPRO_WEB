---
const team = [
  {
    name: 'Ondřej Loskot',
    role: 'Zakladatel & CEO',
    bio: 'Přes 15 let zkušeností v poradenství a digitální transformaci. Dříve konzultant v Deloitte a technologický ředitel v e-commerce startupu.',
    phone: '+420 777 123 456',
    email: 'ondrej@lospro.cz',
    initials: 'OL',
    linkedin: '#',
  },
  {
    name: 'Barbora Marková',
    role: 'Lead Konzultantka',
    bio: 'Specialistka na procesní optimalizaci a change management. Úspěšně provedla transformace v průmyslovém, finančním a zdravotnickém sektoru.',
    phone: '+420 777 234 567',
    email: 'barbora@lospro.cz',
    initials: 'BM',
    linkedin: '#',
  },
  {
    name: 'Jiří Kovář',
    role: 'Head of Development',
    bio: 'Full-stack vývojář s vášní pro čistou architekturu. Vedl vývoj produktů pro firmy jako ČSOB, Mall.cz a Rohlik.cz.',
    phone: '+420 777 345 678',
    email: 'jiri@lospro.cz',
    initials: 'JK',
    linkedin: '#',
  },
  {
    name: 'Lucie Nováková',
    role: 'UX & Produktový design',
    bio: 'Designérka s výcvikem v UX výzkumu a produktovém myšlení. Věří, že nejlepší design je takový, který uživatel nevnímá.',
    phone: '+420 777 456 789',
    email: 'lucie@lospro.cz',
    initials: 'LN',
    linkedin: '#',
  },
];
---

<section id="tym" class="py-24 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-brand-600 font-semibold text-sm tracking-widest uppercase">Tým</span>
      <h2 class="section-title mt-2">Lidé za LOSPRO</h2>
      <p class="section-subtitle">
        Malý, ale výkonný tým s doplňujícími se expertízami. Každý člen přináší
        do projektů unikátní pohled.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {team.map((member, i) => (
        <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 flex flex-col gap-4">
          <!-- Avatar -->
          <div class="flex items-center gap-4">
            <div
              class:list={[
                'w-14 h-14 rounded-2xl flex items-center justify-center text-white font-bold text-lg flex-shrink-0',
                ['bg-brand-600', 'bg-purple-600', 'bg-teal-600', 'bg-orange-500'][i % 4],
              ]}
            >
              {member.initials}
            </div>
            <div>
              <h3 class="font-bold text-gray-900">{member.name}</h3>
              <p class="text-brand-600 text-sm font-medium">{member.role}</p>
            </div>
          </div>

          <!-- Bio -->
          <p class="text-gray-600 text-sm leading-relaxed flex-1">{member.bio}</p>

          <!-- Contacts -->
          <div class="space-y-2 pt-2 border-t border-gray-100">
            <a
              href={`tel:${member.phone.replace(/\s/g, '')}`}
              class="flex items-center gap-2 text-sm text-gray-700 hover:text-brand-600 transition-colors"
            >
              <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              {member.phone}
            </a>
            <a
              href={`mailto:${member.email}`}
              class="flex items-center gap-2 text-sm text-gray-700 hover:text-brand-600 transition-colors"
            >
              <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              {member.email}
            </a>
          </div>

          <!-- LinkedIn -->
          <a
            href={member.linkedin}
            class="flex items-center justify-center gap-2 text-xs font-medium text-gray-500 hover:text-brand-600 border border-gray-200 hover:border-brand-300 rounded-lg py-2 transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
