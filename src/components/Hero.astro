---
---

<section
  id="hero"
  class="relative min-h-screen flex items-center overflow-hidden pt-16"
  style="background: linear-gradient(135deg, #090F1A 0%, #142444 40%, #8B5A2B 75%, #CE8946 100%);"
>
  <!-- Depth layer 1 -->
  <div class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 70% 60% at 15% 20%, rgba(27,48,85,0.7) 0%, transparent 70%);"></div>
  <!-- Depth layer 2 -->
  <div class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 60% 55% at 85% 80%, rgba(206,137,70,0.45) 0%, transparent 65%);"></div>
  <!-- Grid -->
  <div class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: url(\"data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23fff'%3E%3Crect x='0' y='0' width='1' height='40'/%3E%3Crect x='0' y='0' width='40' height='1'/%3E%3C/g%3E%3C/svg%3E\");"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-28 text-center w-full">

    <!-- Logo -->
    <div class="flex justify-center mb-10">
      <img src="/logo.png" alt="LOSPRO Development" class="h-80 w-auto drop-shadow-lg" />
    </div>

    <!-- ── B2C verze (výchozí) ── -->
    <div id="hero-b2c">
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-6 drop-shadow-md">
        Poradíme Vám, jak investovat<br />
        <span style="color: #CE8946;">do nemovitostí bezpečně</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto mb-10 leading-relaxed">
        Od prvního nápadu přes architektonickou studii až po klíč v ruce.
        Stavíme na 25 letech zkušeností a moderní BIM technologii.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#rezervace" class="btn-outline text-base py-3 px-8">
          První konzultace zdarma →
        </a>
        <a href="#o-nas" class="text-gray-300 hover:text-white text-sm font-medium transition-colors flex items-center gap-1">
          Zjistit více
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- ── B2B verze ── -->
    <div id="hero-b2b" class="hidden">
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-6 drop-shadow-md">
        Shaníme partnery pro<br />
        <span style="color: #CE8946;">developerské projekty</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto mb-4 leading-relaxed">
        Máte záměr a hledáte firmu se zkušenostmi a referencemi na velkých projektech?
        Pojďme se pobavit o spolupráci.
      </p>
      <p class="text-gray-400 text-sm mb-10">
        Sjednejte si online schůzku nebo zavolejte ve všední dny
        <strong class="text-gray-200">8:00 – 16:00</strong>
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#rezervace" class="btn-outline text-base py-3 px-8">
          Sjednat online schůzku →
        </a>
        <a
          href="tel:+420777123456"
          class="inline-flex items-center gap-2 text-gray-300 hover:text-white text-sm font-medium transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          +420 777 123 456
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-8">
      {[
        { value: '25+',  label: 'let zkušeností v oboru' },
        { value: 'BIM',  label: 'integrace od A do Z' },
        { value: '360°', label: 'pokrytí projektu' },
        { value: '2025', label: 'rok založení' },
      ].map(stat => (
        <div class="text-center">
          <div class="text-3xl font-extrabold text-white drop-shadow">{stat.value}</div>
          <div class="text-gray-400 text-sm mt-1">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <a href="#o-nas"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/50 hover:text-white transition-colors animate-bounce"
    aria-label="Přejít dolů">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </a>
</section>

<script>
  function applyHeroSector(sector: string) {
    const b2c = document.getElementById('hero-b2c');
    const b2b = document.getElementById('hero-b2b');
    if (!b2c || !b2b) return;
    if (sector === 'b2b') {
      b2c.classList.add('hidden');
      b2b.classList.remove('hidden');
    } else {
      b2b.classList.add('hidden');
      b2c.classList.remove('hidden');
    }
  }

  // On load — read stored selection
  document.addEventListener('DOMContentLoaded', () => {
    try {
      const raw = localStorage.getItem('lospro_sector');
      if (raw) {
        const { sector } = JSON.parse(raw) as { sector: string };
        applyHeroSector(sector);
      }
    } catch {}
  });

  // React immediately when popup fires selection
  window.addEventListener('lospro:sector', (e: Event) => {
    const sector = (e as CustomEvent<string>).detail;
    applyHeroSector(sector);
  });
</script>
