---
---

<!-- Overlay + modal — hidden by default, shown via JS if no valid selection stored -->
<div
  id="sector-popup"
  class="fixed inset-0 z-[100] flex items-center justify-center p-4 hidden"
  style="background: rgba(9,15,26,0.75); backdrop-filter: blur(4px);"
>
  <div
    class="bg-white rounded-3xl shadow-2xl max-w-md w-full p-8 sm:p-10 text-center"
    style="animation: popupIn 0.3s cubic-bezier(0.34,1.56,0.64,1) both;"
  >
    <!-- Logo -->
    <img src="/logo.png" alt="LOSPRO" class="h-12 w-auto mx-auto mb-6" />

    <h2 class="text-2xl font-bold text-gray-900 mb-2">Vítejte na LOSPRO</h2>
    <p class="text-gray-500 text-sm mb-8 leading-relaxed">
      Abychom vám mohli zobrazit relevantní obsah, řekněte nám prosím, kdo jste.
    </p>

    <div class="grid grid-cols-2 gap-4">
      <!-- Podnik -->
      <button
        id="sector-b2b"
        class="group flex flex-col items-center gap-3 p-6 rounded-2xl border-2 border-gray-200 hover:border-brand-500 hover:bg-brand-50 transition-all duration-200 cursor-pointer"
      >
        <div class="w-12 h-12 rounded-xl bg-gray-100 group-hover:bg-brand-100 flex items-center justify-center transition-colors">
          <svg class="w-6 h-6 text-gray-500 group-hover:text-brand-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <span class="font-semibold text-gray-800 group-hover:text-brand-700 transition-colors text-sm">
          Jsem podnik
        </span>
        <span class="text-xs text-gray-400">Developer, investor, firma</span>
      </button>

      <!-- Fyzická osoba -->
      <button
        id="sector-b2c"
        class="group flex flex-col items-center gap-3 p-6 rounded-2xl border-2 border-gray-200 hover:border-brand-500 hover:bg-brand-50 transition-all duration-200 cursor-pointer"
      >
        <div class="w-12 h-12 rounded-xl bg-gray-100 group-hover:bg-brand-100 flex items-center justify-center transition-colors">
          <svg class="w-6 h-6 text-gray-500 group-hover:text-brand-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <span class="font-semibold text-gray-800 group-hover:text-brand-700 transition-colors text-sm">
          Jsem fyzická osoba
        </span>
        <span class="text-xs text-gray-400">Soukromý investor, jednotlivec</span>
      </button>
    </div>

    <p class="text-xs text-gray-300 mt-6">Vaše volba bude uložena na 24 hodin.</p>
  </div>
</div>

<style>
  @keyframes popupIn {
    from { opacity: 0; transform: scale(0.85) translateY(20px); }
    to   { opacity: 1; transform: scale(1)    translateY(0);    }
  }
</style>

<script>
  const STORAGE_KEY = 'lospro_sector';
  const TTL_MS = 24 * 60 * 60 * 1000; // 24 hours

  function shouldShowPopup(): boolean {
    return true; // TEST MODE — vždy zobrazit
  }

  function saveSelection(sector: 'b2b' | 'b2c') {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ sector, ts: Date.now() }));
    window.dispatchEvent(new CustomEvent('lospro:sector', { detail: sector }));
  }

  function closePopup() {
    const popup = document.getElementById('sector-popup');
    if (!popup) return;
    popup.style.opacity = '0';
    popup.style.transition = 'opacity 0.2s ease';
    setTimeout(() => popup.classList.add('hidden'), 200);
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (!shouldShowPopup()) return;

    const popup = document.getElementById('sector-popup');
    popup?.classList.remove('hidden');

    document.getElementById('sector-b2b')?.addEventListener('click', () => {
      saveSelection('b2b');
      closePopup();
    });

    document.getElementById('sector-b2c')?.addEventListener('click', () => {
      saveSelection('b2c');
      closePopup();
    });

    // Close on backdrop click
    popup?.addEventListener('click', (e) => {
      if (e.target === popup) closePopup();
    });
  });
</script>
