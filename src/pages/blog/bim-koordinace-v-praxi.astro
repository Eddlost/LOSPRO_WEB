---
import LayoutFuturistic from '../../layouts/LayoutFuturistic.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const post = {
  cat: 'BIM',
  date: '2026-04-28',
  readTime: '6 min',
  author: 'LOSPRO',
  title: 'BIM koordinace v praxi: jak digitální dvojče šetří miliony',
  lead: 'Placeholder perex — jednovětový hook, který shrne pointu článku a vtáhne čtenáře dovnitř. Nahradí se finálním textem.',
};
---

<LayoutFuturistic title={`${post.title} — LOSPRO Blog`}>

<!-- ======================= NAV ======================= -->
<header class="nav" id="nav">
  <div class="container nav-inner">
    <a href={base} class="logo" data-cursor="hover">
      <span class="logo-mark">L</span>
      <span>LOSPRO</span>
    </a>
    <nav class="mobile-menu" id="mobile-menu">
      <div class="nav-links">
        <a href={`${base}#sluzby`}>01 / Služby</a>
        <a href={`${base}#reference`}>02 / Reference</a>
        <a href={`${base}blog`}>03 / Blog</a>
        <a href={`${base}#kontakt`}>04 / Kontakt</a>
      </div>
    </nav>
    <div class="burger" id="burger">
      <span></span><span></span><span></span>
    </div>
  </div>
</header>

<!-- ======================= ARTICLE ======================= -->
<article class="article">
  <div class="grid-lines"></div>
  <div class="container">
    <div class="article-head">
      <a href={`${base}blog`} class="article-back">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Zpět na blog
      </a>
      <div class="article-meta">
        <span class="blog-cat">{post.cat}</span>
        <span>{post.date}</span>
        <span>{post.readTime} čtení</span>
        <span>{post.author}</span>
      </div>
      <h1>{post.title}</h1>
      <p class="lead">{post.lead}</p>
    </div>

    <div class="article-cover" aria-hidden="true"></div>

    <div class="article-body">
      <p>
        Placeholder odstavec — úvod článku. Lorem ipsum dolor sit amet, consectetur adipiscing elit.
        Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam,
        quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
      </p>

      <h2>Placeholder podnadpis 01</h2>
      <p>
        Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
        Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.
      </p>

      <blockquote>
        "Placeholder citace nebo highlight věty. Nahradí se klíčovým výrokem, který chcete podtrhnout."
      </blockquote>

      <h3>Placeholder pod-podnadpis</h3>
      <p>
        Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium,
        totam rem aperiam, eaque ipsa quae ab illo inventore veritatis et quasi architecto beatae vitae dicta sunt explicabo.
      </p>

      <ul>
        <li>Placeholder bod 01 — krátká teze.</li>
        <li>Placeholder bod 02 — krátká teze.</li>
        <li>Placeholder bod 03 — krátká teze.</li>
      </ul>

      <h2>Placeholder podnadpis 02</h2>
      <p>
        Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit,
        sed quia consequuntur magni dolores eos qui ratione voluptatem sequi nesciunt.
      </p>
      <p>
        Neque porro quisquam est, qui dolorem ipsum quia dolor sit amet, consectetur, adipisci velit,
        sed quia non numquam eius modi tempora incidunt ut labore et dolore magnam aliquam quaerat voluptatem.
      </p>

      <h2>Závěr</h2>
      <p>
        Placeholder závěr — shrnutí a call-to-action. Odkaz na <a href={`${base}#kontakt`} style="color: var(--orange);">kontakt</a> nebo další článek.
      </p>
    </div>

    <div class="article-foot">
      <a href={`${base}blog`} class="article-back" style="margin: 0;">← Všechny články</a>
      <span>// {post.cat} / {post.date}</span>
    </div>
  </div>
</article>

<!-- ======================= FOOTER ======================= -->
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="logo" style="margin-bottom: 1.2rem;">
          <span class="logo-mark">L</span>
          <span>LOSPRO</span>
        </div>
        <p style="font-size: .9rem; max-width: 320px;">Stavební management nové generace. 25+ let zkušeností v pražském developmentu, BIM-first workflow, transparentní reporting.</p>
      </div>
      <div>
        <h5>Navigace</h5>
        <ul>
          <li><a href={base}>Domů</a></li>
          <li><a href={`${base}#sluzby`}>Služby</a></li>
          <li><a href={`${base}#reference`}>Reference</a></li>
          <li><a href={`${base}blog`}>Blog</a></li>
          <li><a href={`${base}#kontakt`}>Kontakt</a></li>
        </ul>
      </div>
      <div>
        <h5>Kontakt</h5>
        <ul>
          <li>info@lospro.cz</li>
          <li>+420 777 123 456</li>
          <li>Křižíkova 148<br/>186 00 Praha 8</li>
        </ul>
      </div>
      <div>
        <h5>Sociální sítě</h5>
        <ul>
          <li><a href="#">Instagram</a></li>
          <li><a href="#">LinkedIn</a></li>
          <li><a href="#">Behance</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-big">LOSPRO.2026</div>

    <div class="footer-bottom">
      <div>© 2026 LOSPRO s.r.o. — IČO 12345678</div>
      <div>Made with concrete & code.</div>
    </div>
  </div>
</footer>

</LayoutFuturistic>
